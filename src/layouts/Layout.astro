---
import "../styles/global.css";
import Floating from "../components/Floating.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WhatsApp from "../components/WhatsApp.astro";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- HTML Meta Tags -->
    <title>Lic. Mur Nutrición</title>
    <meta
      name="description"
      content="Transformá tu alimentación sin dietas restrictivas."
    />

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content="https://murnutricion.com.ar/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Lic. Mur Nutrición" />
    <meta
      property="og:description"
      content="Transformá tu alimentación sin dietas restrictivas. Acompañamiento nutricional online diseñado para tu bienestar integral y un cambio de hábitos sostenible."
    />
    <meta property="og:image" content="https://murnutricion.com.ar/mur.jpg" />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="murnutricion.com.ar" />
    <meta property="twitter:url" content="https://murnutricion.com.ar/" />
    <meta name="twitter:title" content="Lic. Mur Nutrición" />
    <meta
      name="twitter:description"
      content="Transformá tu alimentación sin dietas restrictivas."
    />
    <meta name="twitter:image" content="https://murnutricion.com.ar/mur.jpg" />

    <!-- Google Tag Manager -->
