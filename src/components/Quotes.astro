---
// src/components/Quotes.astro
// No se necesitan props, el texto es estático y exacto.
---

<section id="frases" class="bg-[#F3F0E6] text-[#333333] px-6 md:px-16 py-16 md:py-28 relative overflow-hidden">
  
  <div class="quotes-container max-w-7xl mx-auto flex flex-col md:flex-row gap-10 md:gap-12 items-stretch relative z-10">
    
    <div class="quote-card opacity-0 translate-y-12 scale-95 flex-1 flex flex-col gap-6 p-8 md:p-10 bg-white rounded-3xl border border-stone-100 shadow-xl shadow-stone-100/50 relative overflow-hidden transition-all duration-700 ease-out hover:shadow-2xl hover:shadow-stone-100/80">
      
      <span class="absolute -top-6 -left-6 text-7xl font-serif text-[#E68A73]/15 z-0">“</span>
      
      <div class="w-12 h-12 flex-shrink-0 bg-[#7D8461]/10 text-[#7D8461] rounded-full flex items-center justify-center border border-[#7D8461]/20 relative z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3a1 1 0 10-2 0v1a1 1 0 002 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1m2 0v1a2 2 0 01-2 2H8a2 2 0 01-2-2v-1m2-3.089V10a2 2 0 114 0v2.911l1.414 1.414A1 1 0 0113.828 16H8.172a1 1 0 01-.707-1.707L8 12.911z"></path></svg>
      </div>

      <blockquote class="text-2xl md:text-3xl font-serif leading-tight text-[#333333] relative z-10">
        "No es una dieta,<br> es un <span class="text-[#E68A73]">proceso</span>"
      </blockquote>
    </div>

    <div class="quote-card opacity-0 translate-y-12 scale-95 flex-1 flex flex-col gap-6 p-8 md:p-10 bg-white rounded-3xl border border-stone-100 shadow-xl shadow-stone-100/50 relative overflow-hidden transition-all duration-700 ease-out delay-150 hover:shadow-2xl hover:shadow-stone-100/80">
      
      <span class="absolute -top-6 -left-6 text-7xl font-serif text-[#E68A73]/15 z-0">“</span>
      
      <div class="w-12 h-12 flex-shrink-0 bg-[#7D8461]/10 text-[#7D8461] rounded-full flex items-center justify-center border border-[#7D8461]/20 relative z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
      </div>

      <blockquote class="text-2xl md:text-3xl font-serif leading-tight text-[#333333] relative z-10">
        "Tu alimentación tiene que <span class="relative inline-block px-1 py-0.5 bg-[#E68A73]/10 rounded-full text-[#E68A73]">adaptarse</span> a tu vida"
      </blockquote>
    </div>

    <div class="quote-card opacity-0 translate-y-12 scale-95 flex-1 flex flex-col gap-6 p-8 md:p-10 bg-white rounded-3xl border border-stone-100 shadow-xl shadow-stone-100/50 relative overflow-hidden transition-all duration-700 ease-out delay-300 hover:shadow-2xl hover:shadow-stone-100/80">
      
      <span class="absolute -top-6 -left-6 text-7xl font-serif text-[#E68A73]/15 z-0">“</span>
      
      <div class="w-12 h-12 flex-shrink-0 bg-[#7D8461]/10 text-[#7D8461] rounded-full flex items-center justify-center border border-[#7D8461]/20 relative z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
      </div>

      <blockquote class="text-2xl md:text-3xl font-serif leading-tight text-[#333333] relative z-10">
        "El cambio <span class="relative inline-block px-1 py-0.5 bg-[#E68A73]/10 rounded-full text-[#E68A73]">real</span> es el que podés sostener"
      </blockquote>
    </div>

  </div>
  
  <div class="absolute w-[400px] h-[400px] bg-[#7D8461] rounded-full -bottom-24 -left-20 opacity-[0.05] z-0"></div>
  <div class="absolute w-[300px] h-[300px] bg-[#E68A73] rounded-full -top-16 -right-16 opacity-[0.05] z-0"></div>

</section>

<style>
  /* Clases de utilidad para la animación manejada por JS */
  /* Definimos el estado final de la animación */
  .quote-card.is-visible {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }
</style>

<script>
  // SCRIPT DE COMPATIBILIDAD (Intersection Observer)
  // Se ejecuta en el cliente al cargar el componente.
  
  const quotesContainer = document.querySelector('.quotes-container');
  const quoteCards = quotesContainer.querySelectorAll('.quote-card');

  // Configuración del observador
  const observerOptions = {
    root: null, // usa el viewport
    rootMargin: '0px 0px -10% 0px', // se activa un poco antes de entrar del todo
    threshold: 0.1 // se activa cuando el 10% del elemento es visible
  };

  // Función que se ejecuta cuando cambia la visibilidad
  const observerCallback = (entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Añadimos la clase que dispara la transición CSS
        entry.target.classList.add('is-visible');
        // Dejamos de observar este elemento para ahorrar recursos
        observer.unobserve(entry.target);
      }
    });
  };

  // Creamos el observador
  const observer = new IntersectionObserver(observerCallback, observerOptions);

  // Ponemos a observar cada tarjeta
  quoteCards.forEach(card => {
    observer.observe(card);
  });
</script>