---
// src/components/Navbar.astro
const { logoPath = "/logo.png" } = Astro.props;
---
<nav class="border-b border-stone-200/50 bg-[#FDFBF7] sticky md:fixed top-0 left-0 w-full z-50">
  <div class="max-w-7xl mx-auto px-6 md:px-16 py-4 flex items-center justify-between">
    
    <div class="flex items-center gap-3 w-full justify-center md:w-auto md:justify-start">
      <img src={logoPath} alt="Logo Lic. Mur" class="w-10 h-10 md:w-14 md:h-14 object-contain" />
      
      <div class="flex flex-col justify-center">
        <span class="font-black text-[12px] md:text-sm tracking-[0.15em] text-[#333333] uppercase leading-none mb-1">
          LIC. MUR <span class="hidden md:inline font-normal text-stone-400 mx-1">|</span>
        </span>
        <span class="font-medium text-[9px] md:text-sm tracking-[0.1em] text-stone-500 uppercase leading-none">
          NUTRICIÓN INTEGRAL
        </span>
      </div>
    </div>

    <div id="nav-menu" class="hidden md:flex items-center gap-8">
      <div class="hidden lg:flex items-center gap-8 mr-4">
        <a href="#sobre-mi" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Sobre mí</a>
        <a href="#metodo-mur" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Método MUR</a>
        <a href="#turnos" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Turnos</a>
        <a href="#redes" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Redes</a>
      </div>
      <a href="#" class="bg-[#E68A73] hover:bg-[#2F4F4F] text-white font-bold text-xs tracking-widest uppercase px-6 py-3.5 rounded-lg transition-colors">
        Reservar Turno
      </a>
    </div>

  </div>
</nav>

<div class="hidden md:block h-[80px]"></div>

<script>
  // SCRIPT PARA SMOOTH SCROLL (Desplazamiento Suave)
  // Este script se ejecuta en el navegador del cliente.

  // 1. Seleccionamos el menú de navegación
  const navMenu = document.getElementById('nav-menu');
  
  if (navMenu) {
    // 2. Buscamos todos los enlaces ancla (que empiezan con #) dentro del menú
    const links = navMenu.querySelectorAll('a[href^="#"]');

    links.forEach(link => {
      link.addEventListener('click', function(e) {
        // 3. Prevenimos el comportamiento por defecto del salto instantáneo
        e.preventDefault();

        // 4. Obtenemos el ID de destino del atributo href
        const targetId = this.getAttribute('href');
        
        // Evitamos errores si el href es solo "#"
        if (targetId === '#') return;

        const targetElement = document.querySelector(targetId);

        if (targetElement) {
          // 5. Calculamos la posición final, restando el alto de la navbar fixed (80px)
          const offset = 80; // Alto de la navbar en desktop (md:fixed h-[80px])
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - offset;

          // 6. Realizamos el scroll suave nativo del navegador
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth' // Esta es la clave de la magia
          });
        }
      });
    });
  }
</script>