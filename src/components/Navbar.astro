---
const { logoPath = "/logo-mur.png" } = Astro.props;
---
<nav id="navbar-main" class="border-b border-stone-200/50 bg-[#FDFBF7] sticky md:fixed top-0 left-0 w-full z-50">
  <div class="max-w-7xl mx-auto px-6 md:px-16 py-4 flex items-center justify-between">
    
    <a href="#inicio" class="flex items-center w-full justify-center md:w-auto md:justify-start">
      <img src={logoPath} alt="Logo Lic. Mur" class="h-16 md:h-20 w-auto object-contain" />
    </a>

    <div id="nav-menu" class="hidden md:flex items-center gap-8">
      <div class="hidden lg:flex items-center gap-8 mr-4">
        <a href="#sobre-mi" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Sobre mí</a>
        <a href="#metodo-mur" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Método MUR</a>
        <a href="#turnos" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Turnos</a>
        <a href="#redes" class="font-bold text-xs tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors">Redes</a>
      </div>
      <a href="#turno-form" class="bg-[#E68A73] hover:bg-[#2F4F4F] text-white font-bold text-xs tracking-widest uppercase px-6 py-3.5 rounded-lg transition-colors">
        Reservar Turno
      </a>
    </div>

  </div>
</nav>

<div class="hidden md:block h-[80px]"></div>

<script>
  // SCRIPT ACTUALIZADO PARA SMOOTH SCROLL UNIVERSAL
  // Se ejecuta en el navegador del cliente.

  // 1. Seleccionamos toda la etiqueta <nav> (incluye logo y menú)
  const navbarMain = document.getElementById('navbar-main');
  
  if (navbarMain) {
    // 2. Buscamos TODOS los enlaces ancla (que empiezan con #) dentro de toda la Navbar
    // Usamos 'a[href^="#"]' para ser precisos.
    const allAnchorLinks = navbarMain.querySelectorAll('a[href^="#"]');

    allAnchorLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // 3. Prevenimos el salto instantáneo
        e.preventDefault();

        // 4. Obtenemos el ID de destino (ej: #sobre-mi, #inicio)
        const targetId = this.getAttribute('href');
        
        // Evitamos errores si el href es solo "#"
        if (targetId === '#') return;

        const targetElement = document.querySelector(targetId);

        if (targetElement) {
          // 5. Calculamos la posición final, restando el offset (80px)
          const offset = 80; // Alto de la navbar simulado (md:fixed h-[80px])
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - offset;

          // 6. Scroll suave nativo
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth' // La magia está acá
          });
        }
      });
    });
  }
</script>