---
const { imagePath = "/stock-nutri.jpg" } = Astro.props;
---

<section id="inicio" class="relative bg-[#FDFBF7] text-[#333333] px-6 md:px-16 py-12 md:py-24 overflow-hidden min-h-[620px]">
  
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20 relative z-10">
    
    <div class="flex-1 w-full flex flex-col items-center text-center lg:items-start lg:text-left gap-6 lg:gap-10">
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif leading-[1.1] tracking-tight uppercase">
        Transformá tu<br>
        alimentación<br>
        <span class="text-[#E68A73]">sin dietas restrictivas<br></span>
      </h1>
      
      <p class="text-lg md:text-xl font-normal text-[#333333]/80 leading-relaxed max-w-xl">
        Acompañamiento nutricional online, sin dietas restrictivas, diseñado para tu bienestar integral.
      </p>
      <div class="flex flex-col sm:flex-row items-center lg:items-center gap-6 lg:gap-8 pt-4 w-full justify-center lg:justify-start">
  
  <a href="#turno-form" class="hidden md:inline-block bg-[#E68A73] hover:bg-[#2F4F4F] text-white font-bold text-sm tracking-widest uppercase px-10 py-5 rounded-full transition-colors w-full md:w-auto text-center shadow-lg shadow-[#E68A73]/20">
    Empezar mi proceso
  </a>
  
  <a href="#metodo-mur" class="inline-flex items-center gap-2 font-bold text-sm tracking-widest text-[#333333] uppercase hover:text-[#E68A73] transition-colors border-b-2 border-[#E68A73]/30 hover:border-[#E68A73] pb-1 whitespace-nowrap">
    Conocé el Método MUR <span class="text-xl">→</span>
  </a>

</div>
      
      <p class="text-xs text-[#333333]/60">Consultas online en español e inglés.</p>
    </div>

    <div class="flex-1 w-full relative flex justify-center items-center">
      <div class="absolute w-40 h-40 bg-[#E68A73] rounded-full -top-10 -right-10 opacity-20 z-0"></div>
      <div class="absolute w-24 h-24 bg-[#7D8461] rounded-full bottom-[-20px] left-[-30px] opacity-15 z-0"></div>

      <div class="w-full max-w-[450px] aspect-[4/5] rounded-3xl overflow-hidden relative z-10 border border-stone-100 shadow-xl shadow-stone-100/50">
        <img 
          src={imagePath} 
          alt="Lic. Mur - Nutricionista" 
          class="w-full h-full object-cover object-top" 
        />
      </div>
    </div>
    
  </div>
  
  <div class="absolute w-[600px] h-[600px] bg-[#333333] rounded-full -bottom-48 -left-20 opacity-[0.02] z-0"></div>

</section>