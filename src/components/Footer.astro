---
// src/components/Footer.astro
// No se necesitan props, el texto es estático y exacto.
---

<footer id="contacto" class="bg-[#E68A73] text-white px-6 md:px-16 py-16 md:py-24 relative overflow-hidden">
  
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start relative z-10">
    
    <div class="flex flex-col gap-6 items-start">
      
      <div class="flex flex-col gap-2">
        <span class="font-black text-2xl tracking-widest uppercase">
          Lic. Estefanía Murstein
        </span>
        <span class="font-medium text-sm tracking-[0.15em] uppercase opacity-90">
          Nutrición Integral
        </span>
      </div>

      <p class="text-sm font-normal leading-relaxed max-w-md opacity-80">
        Transformá tu alimentación y construí hábitos reales sin dietas restrictivas. Acompañamiento online personalizado para tu bienestar integral.
      </p>
    </div>

    <div class="flex flex-col gap-8 items-start md:items-end w-full">
      
      <h3 class="text-xs md:text-sm font-sans font-medium uppercase tracking-widest opacity-90">
        Conectemos en Redes
      </h3>
      
      <hr class="w-16 md:w-24 border-t-2 border-white opacity-40">

      <ul class="grid grid-cols-1 gap-y-6 w-full max-w-[300px] md:max-w-none md:justify-items-end">
        
        <li>
          <a href="https://www.instagram.com/lic_mur_nutricion/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group transition-colors hover:text-[#2F4F4F]">
            <div class="w-10 h-10 flex-shrink-0 bg-white/10 text-white rounded-full flex items-center justify-center border border-white/20 mt-0.5 transition-colors group-hover:bg-white group-hover:text-[#2F4F4F]">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849s-.011 3.585-.069 4.85c-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07s-3.584-.012-4.85-.07c-3.26-.149-4.771-1.699-4.919-4.919-.058 1.265-.069-1.645-.069-4.849s.011-3.585.069-4.85c.149-3.225 1.664-4.771 4.919-4.919 1.266-.058 1.645-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.667.072 4.947c.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072s3.667-.014 4.947-.072c4.358-.2 6.78-2.618 6.98-6.98.058-1.281.072-1.689.072-4.948s-.014-3.667-.072-4.947c-.2-4.358-2.618-6.78-6.98-6.98-1.281-.059-1.689-.073-4.948-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </div>
            <p class="text-base font-medium leading-relaxed">@lic_mur_nutricion</p>
          </a>
        </li>

        <li>
          <a href="https://www.linkedin.com/in/lic-em/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group transition-colors hover:text-[#2F4F4F]">
            <div class="w-10 h-10 flex-shrink-0 bg-white/10 text-white rounded-full flex items-center justify-center border border-white/20 mt-0.5 transition-colors group-hover:bg-white group-hover:text-[#2F4F4F]">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </div>
            <p class="text-base font-medium leading-relaxed truncate max-w-[180px] md:max-w-[220px]">linkedin.com/in/lic-em/</p>
          </a>
        </li>

      </ul>
    </div>
    
  </div>
  
  <hr class="w-full border-t border-white opacity-20 my-12 relative z-10">

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-normal opacity-70 relative z-10">
    <p>© {new Date().getFullYear()} Lic. Estefanía Murstein. Todos los derechos reservados.</p>
    <p>Diseño & Desarrollo: <a href="https://martintavella.dev" target="_blank" rel="noopener noreferrer" class="underline hover:text-[#2F4F4F]">Martin Tavella</a></p>
  </div>
  
  <div class="absolute w-[400px] h-[400px] bg-white rounded-full -top-32 -left-20 opacity-[0.05] z-0"></div>
  <div class="absolute w-[300px] h-[300px] bg-white rounded-full -bottom-16 -right-16 opacity-[0.05] z-0"></div>

</footer>