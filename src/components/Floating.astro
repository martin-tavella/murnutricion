<div id="floating-cta" class="fixed bottom-0 left-0 w-full p-4 z-[100] md:hidden transition-all duration-500 transform translate-y-0 opacity-100">
  <div class="bg-white/80 backdrop-blur-md p-2 rounded-2xl border border-stone-200/50 shadow-[0_-10px_25px_-5px_rgba(0,0,0,0.05)]">
    <a 
      href="#turno-form" 
      class="flex items-center justify-center bg-[#E68A73] hover:bg-[#2F4F4F] text-white font-bold text-sm tracking-widest uppercase px-8 py-4 rounded-xl transition-all active:scale-[0.98] shadow-lg shadow-[#E68A73]/20"
    >
      Empezá tu proceso
    </a>
  </div>
</div>

<style>
  .cta-hidden {
    transform: translateY(100%);
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  const floatingCta = document.getElementById('floating-cta');
  const targetSection = document.getElementById('turno-form');

  if (floatingCta && targetSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        // Si el formulario está visible en más de un 10%, ocultamos el CTA
        if (entry.isIntersecting) {
          floatingCta.classList.add('cta-hidden');
        } else {
          floatingCta.classList.remove('cta-hidden');
        }
      });
    }, {
      // Ajustamos el margen para que desaparezca un poco antes de llegar al form
      rootMargin: '0px',
      threshold: 0.1 
    });

    observer.observe(targetSection);
  }
</script>