    <div class="relative flex justify-center items-center">
      
      <div class="w-full max-w-[320px] aspect-[3/4] rounded-2xl bg-white border border-stone-100 p-8 flex flex-col justify-between shadow-xl shadow-stone-100/50 relative z-10 overflow-hidden">
        
        <div class="absolute w-28 h-28 bg-[#7D8461] rounded-full bottom-[-40px] right-[-40px] opacity-10 z-0"></div>

        <div class="relative flex flex-col gap-6 z-10 items-start">
          
          <span class="text-xs font-sans font-medium text-[#7D8461] uppercase tracking-widest bg-[#7D8461]/10 px-3 py-1.5 rounded-full border border-[#7D8461]/20">
