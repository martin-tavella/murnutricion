---
// src/components/About.astro
const { imagePath = "/mur.jpeg" } = Astro.props;
---

<section id="sobre-mi" class="bg-[#FDFBF7] px-6 md:px-16 py-16 md:py-28 relative overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-12 md:gap-20 items-center relative z-10">
    
    <div class="reveal relative md:flex justify-center items-center hidden">
      <div class="about-image-container w-full max-w-[380px] aspect-[4/5] rounded-3xl overflow-hidden border border-stone-100 shadow-xl shadow-stone-100/50 relative z-10">
        <img 
          src={imagePath} 
          alt="Estefanía Murstein - Licenciada en Nutrición" 
          class="w-full h-full object-cover object-top" 
        />
      </div>
      <div class="absolute w-20 h-20 bg-[#E68A73] rounded-full -top-6 -left-6 opacity-20 z-0"></div>
    </div>

    <div class="reveal w-full flex flex-col gap-10">
      <div class="flex flex-col gap-3">
        <h2 class="text-xs md:text-sm font-sans font-medium text-[#7D8461] uppercase tracking-widest">Sobre Mí</h2>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight tracking-tight text-[#333333] uppercase font-black">
          Soy <span class="text-[#E68A73]">Estefanía<br class="hidden md:inline"> Murstein</span>
        </h3>
        <span class="inline-block mt-2 text-sm md:text-base font-sans font-medium text-[#7D8461] uppercase tracking-widest bg-[#7D8461]/10 px-4 py-2 rounded-full border border-[#7D8461]/20 self-start">
          Licenciada en Nutrición
        </span>
      </div>

      <p class="text-lg md:text-xl font-normal text-[#333333]/90 leading-relaxed max-w-2xl font-serif">
          "Trabajo con personas que están cansadas de empezar dietas y no poder sostenerlas."
      </p>

      <hr class="w-24 border-t-2 border-[#E68A73] opacity-60">
      
       
    <div class="reveal relative md:hidden justify-center items-center flex">
      <div class="about-image-container w-full max-w-[380px] max-h-[380px] aspect-[1/1] rounded-3xl overflow-hidden border border-stone-100 shadow-xl shadow-stone-100/50 relative z-10">
        <img 
          src={imagePath} 
          alt="Estefanía Murstein - Licenciada en Nutrición" 
          class="w-full h-full object-cover object-top" 
        />
      </div>
      <div class="absolute w-20 h-20 bg-[#E68A73] rounded-full -top-6 -left-6 opacity-20 z-0"></div>
    </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-10">
            <li class="flex items-start gap-4">
          <div class="w-10 h-10 flex-shrink-0 bg-[#E68A73]/10 text-[#E68A73] rounded-full flex items-center justify-center border border-[#E68A73]/20 mt-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3a1 1 0 10-2 0v1a1 1 0 002 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1m2 0v1a2 2 0 01-2 2H8a2 2 0 01-2-2v-1m2-3.089V10a2 2 0 114 0v2.911l1.414 1.414A1 1 0 0113.828 16H8.172a1 1 0 01-.707-1.707L8 12.911z"></path></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm text-[#333333] uppercase tracking-wider mb-1">Mi enfoque</h4>
            <p class="text-sm text-[#333333]/80 leading-relaxed">Combina nutrición, organización de hábitos y el vínculo emocional con la comida, para lograr cambios reales y sostenibles.</p>
          </div>
        </li>

        <li class="flex items-start gap-4">
          <div class="w-10 h-10 flex-shrink-0 bg-[#7D8461]/10 text-[#7D8461] rounded-full flex items-center justify-center border border-[#7D8461]/20 mt-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm text-[#333333] uppercase tracking-wider mb-1">Procesos a tu medida</h4>
            <p class="text-sm text-[#333333]/80 leading-relaxed">No trabajo con planes rígidos ni soluciones rápidas, sino con procesos adaptados a tu vida.</p>
          </div>
        </li>

        <li class="flex items-start gap-4">
          <div class="w-10 h-10 flex-shrink-0 bg-[#7D8461]/10 text-[#7D8461] rounded-full flex items-center justify-center border border-[#7D8461]/20 mt-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h1.5a2.5 2.5 0 002.5-2.5V4m-5 0h2a2 2 0 002-2.31M16 2a2 2 0 01-1.318.31M13 22l1-4.318"></path></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm text-[#333333] uppercase tracking-wider mb-1">100% Online y Global</h4>
            <p class="text-sm text-[#333333]/80 leading-relaxed">Sesiones personalizadas en español e inglés, desde cualquier lugar del mundo.</p>
          </div>
        </li>

      </ul>
    </div>
  </div>
</section>
<style>
  /* Estado inicial: Invisible y un poco abajo */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
  }

  /* Estado cuando entra en pantalla */
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.15 // Se activa cuando se ve el 15% del elemento
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("active");
      }
    });
  }, observerOptions);

  // Seleccionamos todos los elementos con la clase reveal
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

        
      