---
// src/components/SocialCta.astro
// No se necesitan props, el texto es estático y exacto.
---

<section id="redes" class="bg-[#FDFBF7] text-[#333333] px-6 md:px-16 py-16 md:py-28 relative overflow-hidden">
  
  <div class="max-w-7xl mx-auto flex flex-col items-center gap-12 md:gap-16 relative z-10 overflow-hidden">
    
    <div class="flex flex-col gap-3 text-center max-w-2xl">
      <h2 class="text-xs md:text-sm font-sans font-medium text-[#7D8461] uppercase tracking-widest">
        Conectemos
      </h2>
      <h3 class="text-4xl md:text-5xl lg:text-6xl font-serif leading-tight tracking-tight text-[#333333] uppercase font-black">
        Seguinos en <span class="text-[#E68A73]">Redes</span>
      </h3>
      <p class="mt-4 text-base md:text-lg font-normal text-[#333333]/80 leading-relaxed font-sans">
        Sumate a nuestra comunidad para recibir tips, recetas y contenido exclusivo sobre nutrición integral y bienestar.
      </p>
    </div>

    <hr class="w-24 border-t-2 border-[#E68A73] opacity-60">

    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-stretch">
      
      <a href="https://www.instagram.com/lic_mur_nutricion/" target="_blank" rel="noopener noreferrer" class="group flex flex-col gap-8 p-8 md:p-10 bg-white rounded-3xl border border-stone-100 shadow-xl shadow-stone-100/50 relative overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-stone-100/80 hover:-translate-y-2">
        
        <div class="absolute w-40 h-40 bg-[#E68A73] rounded-full bottom-[-60px] right-[-60px] opacity-10 z-0"></div>

        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 z-10">
          <div class="w-16 h-16 md:w-20 md:h-20 flex-shrink-0 bg-[#E68A73]/10 text-[#E68A73] rounded-full flex items-center justify-center border-4 border-[#E68A73]/20 group-hover:bg-[#E68A73] group-hover:text-white transition-colors duration-300 overflow-hidden">
            <svg class="w-10 h-10 md:w-12 md:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849s-.011 3.585-.069 4.85c-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07s-3.584-.012-4.85-.07c-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.069-1.645-.069-4.849s.011-3.585.069-4.85c.149-3.225 1.664-4.771 4.919-4.919 1.266-.058 1.645-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.667.072 4.947c.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072s3.667-.014 4.947-.072c4.358-.2 6.78-2.618 6.98-6.98.058-1.281.072-1.689.072-4.948s-.014-3.667-.072-4.947c-.2-4.358-2.618-6.78-6.98-6.98-1.281-.059-1.689-.073-4.948-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <div class="flex flex-col items-center md:items-start gap-1">
            <span class="text-xs md:text-sm font-sans font-medium text-[#7D8461] uppercase tracking-widest text-center md:text-left">
              Instagram
            </span>
            <h4 class="text-xl md:text-3xl font-serif text-[#333333] font-black group-hover:text-[#E68A73] transition-colors duration-300 text-center md:text-left">
              @lic_mur_nutricion
            </h4>
          </div>
        </div>

        <div class="flex flex-col gap-4 z-10 items-center md:items-start text-center md:text-left">
          <p class="text-sm md:text-base text-[#333333]/90 leading-relaxed max-w-md">
            Seguinos para tips diarios, recetas saludables y el día a día de la nutrición integral.
          </p>
          <span class="text-sm font-bold tracking-widest text-[#E68A73] uppercase group-hover:text-[#2F4F4F] transition-colors duration-300">
            Ver Perfil →
          </span>
        </div>

      </a>

      <a href="https://www.linkedin.com/in/lic-em/" target="_blank" rel="noopener noreferrer" class="group flex flex-col gap-8 p-8 md:p-10 bg-white rounded-3xl border border-stone-100 shadow-xl shadow-stone-100/50 relative overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-stone-100/80 hover:-translate-y-2">
        
        <div class="absolute w-40 h-40 bg-[#7D8461] rounded-full bottom-[-60px] right-[-60px] opacity-10 z-0"></div>

        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 z-10 overflow-hidden w-full">
          <div class="w-16 h-16 md:w-20 md:h-20 flex-shrink-0 bg-[#0077B5]/10 text-[#0077B5] rounded-full flex items-center justify-center border-4 border-[#0077B5]/20 group-hover:bg-[#0077B5] group-hover:text-white transition-colors duration-300 overflow-hidden">
            <svg class="w-10 h-10 md:w-12 md:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <div class="flex flex-col items-center md:items-start gap-1 overflow-hidden w-full max-w-full md:max-w-none">
            <span class="text-xs md:text-sm font-sans font-medium text-[#7D8461] uppercase tracking-widest text-center md:text-left">
              LinkedIn
            </span>
            <h4 class="text-xl md:text-3xl font-serif leading-[1.3] text-[#333333] font-black group-hover:text-[#0077B5] transition-colors duration-300 text-center md:text-left break-words hyphens-auto w-full">
              linkedin.com/in/lic-em/
            </h4>
          </div>
        </div>

        <div class="flex flex-col gap-4 z-10 items-center md:items-start text-center md:text-left">
          <p class="text-sm md:text-base text-[#333333]/90 leading-relaxed max-w-md">
            Conectá profesionalmente para novedades sobre nutrición clínica e integral.
          </p>
          <span class="text-sm font-bold tracking-widest text-[#0077B5] uppercase group-hover:text-[#2F4F4F] transition-colors duration-300">
            Ver Perfil →
          </span>
        </div>

      </a>

    </div>
    
  </div>
  
  <div class="absolute w-[500px] h-[500px] bg-[#7D8461] rounded-full -bottom-48 -left-20 opacity-[0.03] z-0"></div>
  <div class="absolute w-[300px] h-[300px] bg-[#E68A73] rounded-full -top-16 -right-16 opacity-[0.03] z-0"></div>

</section>